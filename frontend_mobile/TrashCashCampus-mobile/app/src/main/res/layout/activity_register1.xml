<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/ivRegisterIllustration"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:adjustViewBounds="true"
            android:contentDescription="Recycling illustration"
            android:src="@drawable/email_logo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.8" />

        <TextView
            android:id="@+id/tvCreateAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Create account"
            android:textColor="#333333"
            android:textSize="30sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ivRegisterIllustration" />

        <!-- Progress indicator with circle steps to match other screens -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clProgressIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toBottomOf="@+id/tvCreateAccount">

            <!-- Text labels -->
            <TextView
                android:id="@+id/tvEmailStep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="#333333"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@+id/vCircleEmail"
                app:layout_constraintEnd_toEndOf="@+id/vCircleEmail"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvNameStep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textColor="#BBBBBB"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@+id/vCircleName"
                app:layout_constraintEnd_toEndOf="@+id/vCircleName"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvBirthdayStep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Birthday"
                android:textColor="#BBBBBB"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@+id/vCircleBirthday"
                app:layout_constraintEnd_toEndOf="@+id/vCircleBirthday"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvGenderStep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gender"
                android:textColor="#BBBBBB"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@+id/vCircleGender"
                app:layout_constraintEnd_toEndOf="@+id/vCircleGender"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Connector lines positioned behind the circles -->
            <View
                android:id="@+id/vConnectorLineBackground"
                android:layout_width="0dp"
                android:layout_height="3dp"
                android:background="#DDDDDD"
                app:layout_constraintStart_toStartOf="@+id/vCircleEmail"
                app:layout_constraintEnd_toEndOf="@+id/vCircleGender"
                app:layout_constraintTop_toTopOf="@+id/vCircleEmail"
                app:layout_constraintBottom_toBottomOf="@+id/vCircleEmail" />

            <!-- Progress connector line to be animated -->
            <View
                android:id="@+id/vConnectorLineProgress"
                android:layout_width="0dp"
                android:layout_height="3dp"
                android:background="@color/orange_progress"
                android:scaleX="0"
                android:pivotX="0"
                app:layout_constraintStart_toStartOf="@+id/vCircleEmail"
                app:layout_constraintEnd_toStartOf="@+id/vCircleName"
                app:layout_constraintTop_toTopOf="@+id/vCircleEmail"
                app:layout_constraintBottom_toBottomOf="@+id/vCircleEmail" />

            <!-- Circles positioned to be evenly spaced -->
            <View
                android:id="@+id/vCircleEmail"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/circle_unselected"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/vCircleName"
                app:layout_constraintTop_toBottomOf="@+id/tvEmailStep"
                app:layout_constraintHorizontal_chainStyle="spread_inside" />

            <View
                android:id="@+id/vCircleName"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/circle_unselected"
                app:layout_constraintStart_toEndOf="@+id/vCircleEmail"
                app:layout_constraintEnd_toStartOf="@+id/vCircleBirthday"
                app:layout_constraintTop_toTopOf="@+id/vCircleEmail" />

            <View
                android:id="@+id/vCircleBirthday"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/circle_unselected"
                app:layout_constraintStart_toEndOf="@+id/vCircleName"
                app:layout_constraintEnd_toStartOf="@+id/vCircleGender"
                app:layout_constraintTop_toTopOf="@+id/vCircleEmail" />

            <View
                android:id="@+id/vCircleGender"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/circle_unselected"
                app:layout_constraintStart_toEndOf="@+id/vCircleBirthday"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/vCircleEmail" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tvEmailLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Email"
            android:textColor="#333333"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/clProgressIndicator" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field_animated"
            android:hint="example@cit.edu"
            android:inputType="textEmailAddress"
            android:padding="16dp"
            android:textColor="#757575"
            android:textColorHint="#BBBBBB"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvEmailLabel" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnContinue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_button_green_consistent"
            android:padding="16dp"
            android:text="Continue"
            android:textAlignment="center"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/etEmail" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnContinue">

            <TextView
                android:id="@+id/tvHaveAccount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Have an account?"
                android:textColor="#333333"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvLogIn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Log in"
                android:textColor="#34A853"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Loading overlay -->
        <RelativeLayout
            android:id="@+id/loadingOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#80FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:indeterminateTint="#34A853" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/progressBar"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="8dp"
                android:text="Checking email..."
                android:textColor="#333333"
                android:textSize="14sp" />
        </RelativeLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>