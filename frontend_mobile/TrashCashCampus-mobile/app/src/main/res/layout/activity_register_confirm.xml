<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/ivConfirmationIllustration"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:adjustViewBounds="true"
            android:contentDescription="Confirmation illustration"
            android:src="@drawable/login_illustration"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.7" />

        <TextView
            android:id="@+id/tvConfirmationTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Enter Confirmation Code"
            android:textColor="#333333"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ivConfirmationIllustration" />

        <!-- Progress indicator with all steps completed -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clProgressIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@+id/tvConfirmationTitle">

            <!-- Text labels -->
            <TextView
                android:id="@+id/tvEmailStep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="#FF7143"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@+id/vCircleEmail"
                app:layout_constraintEnd_toEndOf="@+id/vCircleEmail"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvNameStep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textColor="#FF7143"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@+id/vCircleName"
                app:layout_constraintEnd_toEndOf="@+id/vCircleName"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvBirthdayStep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Birthday"
                android:textColor="#FF7143"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@+id/vCircleBirthday"
                app:layout_constraintEnd_toEndOf="@+id/vCircleBirthday"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvGenderStep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gender"
                android:textColor="#FF7143"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@+id/vCircleGender"
                app:layout_constraintEnd_toEndOf="@+id/vCircleGender"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvPassStep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pass"
                android:textColor="#FF7143"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@+id/vCirclePass"
                app:layout_constraintEnd_toEndOf="@+id/vCirclePass"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Connector lines positioned behind the circles -->
            <View
                android:id="@+id/vConnectorLineBackground"
                android:layout_width="0dp"
                android:layout_height="3dp"
                android:background="#DDDDDD"
                app:layout_constraintStart_toStartOf="@+id/vCircleEmail"
                app:layout_constraintEnd_toEndOf="@+id/vCirclePass"
                app:layout_constraintTop_toTopOf="@+id/vCircleEmail"
                app:layout_constraintBottom_toBottomOf="@+id/vCircleEmail" />

            <!-- Connector lines for completed steps (orange) -->
            <View
                android:id="@+id/vConnectorLineCompleted"
                android:layout_width="0dp"
                android:layout_height="3dp"
                android:background="#FF7143"
                app:layout_constraintStart_toStartOf="@+id/vCircleEmail"
                app:layout_constraintEnd_toEndOf="@+id/vCirclePass"
                app:layout_constraintTop_toTopOf="@+id/vCircleEmail"
                app:layout_constraintBottom_toBottomOf="@+id/vCircleEmail" />

            <!-- Circles positioned to be evenly spaced -->
            <ImageView
                android:id="@+id/vCircleEmail"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/circle_selected"
                android:src="@drawable/ic_check"
                android:padding="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/vCircleName"
                app:layout_constraintTop_toBottomOf="@+id/tvEmailStep"
                app:layout_constraintHorizontal_chainStyle="spread_inside" />

            <ImageView
                android:id="@+id/vCircleName"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/circle_selected"
                android:src="@drawable/ic_check"
                android:padding="8dp"
                app:layout_constraintStart_toEndOf="@+id/vCircleEmail"
                app:layout_constraintEnd_toStartOf="@+id/vCircleBirthday"
                app:layout_constraintTop_toTopOf="@+id/vCircleEmail" />

            <ImageView
                android:id="@+id/vCircleBirthday"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/circle_selected"
                android:src="@drawable/ic_check"
                android:padding="8dp"
                app:layout_constraintStart_toEndOf="@+id/vCircleName"
                app:layout_constraintEnd_toStartOf="@+id/vCircleGender"
                app:layout_constraintTop_toTopOf="@+id/vCircleEmail" />

            <ImageView
                android:id="@+id/vCircleGender"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/circle_selected"
                android:src="@drawable/ic_check"
                android:padding="8dp"
                app:layout_constraintStart_toEndOf="@+id/vCircleBirthday"
                app:layout_constraintEnd_toStartOf="@+id/vCirclePass"
                app:layout_constraintTop_toTopOf="@+id/vCircleEmail" />

            <ImageView
                android:id="@+id/vCirclePass"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/circle_selected"
                android:src="@drawable/ic_check"
                android:padding="8dp"
                app:layout_constraintStart_toEndOf="@+id/vCircleGender"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/vCircleEmail" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Confirmation code instructions -->
        <TextView
            android:id="@+id/tvConfirmationInstructions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Enter the 6-digit code we sent to john@doe.com"
            android:textColor="#333333"
            android:textSize="16sp"
            android:textAlignment="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/clProgressIndicator"
            app:layout_constraintWidth_percent="0.8" />

        <!-- Resend code button -->
        <TextView
            android:id="@+id/tvResendCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Resend code"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvConfirmationInstructions" />

        <!-- Verification code input field -->
        <LinearLayout
            android:id="@+id/llVerificationCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@+id/tvResendCode">

            <!-- 6 individual code digit boxes -->
            <EditText
                android:id="@+id/etCodeDigit1"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_input_field_rounded"
                android:inputType="number"
                android:maxLength="1"
                android:textAlignment="center"
                android:textSize="20sp"
                android:textColor="#333333" />

            <EditText
                android:id="@+id/etCodeDigit2"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_input_field_rounded"
                android:inputType="number"
                android:maxLength="1"
                android:textAlignment="center"
                android:textSize="20sp"
                android:textColor="#333333" />

            <EditText
                android:id="@+id/etCodeDigit3"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_input_field_rounded"
                android:inputType="number"
                android:maxLength="1"
                android:textAlignment="center"
                android:textSize="20sp"
                android:textColor="#333333" />

            <EditText
                android:id="@+id/etCodeDigit4"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_input_field_rounded"
                android:inputType="number"
                android:maxLength="1"
                android:textAlignment="center"
                android:textSize="20sp"
                android:textColor="#333333" />

            <EditText
                android:id="@+id/etCodeDigit5"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_input_field_rounded"
                android:inputType="number"
                android:maxLength="1"
                android:textAlignment="center"
                android:textSize="20sp"
                android:textColor="#333333" />

            <EditText
                android:id="@+id/etCodeDigit6"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_input_field_rounded"
                android:inputType="number"
                android:maxLength="1"
                android:textAlignment="center"
                android:textSize="20sp"
                android:textColor="#333333" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnConfirm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_button_green"
            android:padding="16dp"
            android:text="Confirm"
            android:textAlignment="center"
            android:textAllCaps="false"
            android:textColor="#333333"
            app:layout_constraintWidth_percent="0.9"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/llVerificationCode" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>