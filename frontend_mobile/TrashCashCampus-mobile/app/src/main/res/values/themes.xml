<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Trashcashcampusmobile" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/primary_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        
        <!-- Button styles -->
        <item name="buttonStyle">@style/Widget.MaterialComponents.Button</item>
    </style>
    
    <!-- Splash Screen Theme -->
    <style name="Theme.Trashcashcampusmobile.Splash" parent="Theme.Trashcashcampusmobile">
        <item name="android:windowBackground">@color/splash_start_color</item>
        <item name="android:statusBarColor">@color/splash_start_color</item>
        <item name="android:navigationBarColor">@color/splash_start_color</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>